rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // All authenticated users can read routes & trips
    match /routes/{routeId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /trips/{tripId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Users: each user can read/write their own document
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;
    }

    // Operators: each operator can read/write their own document
    match /operators/{oprId} {
      allow read, write: if request.auth.uid == oprId;
    }

    // Buses: operator may CRUD only their own buses
    match /buses/{busId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == resource.data.operatorId;
    }

    // Active bookings: user may create/read their own; operator may read for their buses
    match /active-bookings/{bookingId} {
      allow create: if request.auth.uid == request.resource.data.userId;
      allow read: if request.auth.uid == resource.data.userId
                   || request.auth.uid == resource.data.operatorId;
      allow update, delete: if request.auth.uid == resource.data.userId;
    }

    // Past bookings – only users view their own history
    match /past-bookings/{histId} {
      allow read: if request.auth.uid == resource.data.userId;
      allow write: if false;
    }
  }
}
